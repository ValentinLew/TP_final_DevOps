Vagrant.configure("2") do |config|
  config.vm.box = "debian/bookworm64"
  config.ssh.insert_key = false

  nodes = {
    "k3s" => {
      ip: "192.168.56.10",
      ssh_port: 2222,
      memory: 2048,
      cpus: 2
    },
    "monitoring" => {
      ip: "192.168.56.20",
      ssh_port: 2223,
      memory: 1024,
      cpus: 1
    }
  }

  nodes.each do |name, opts|
    config.vm.define name do |node|
      node.vm.hostname = name
      node.vm.network "private_network", ip: opts[:ip]
      node.vm.network "forwarded_port",
        guest: 22,
        host: opts[:ssh_port],
        host_ip: "0.0.0.0",
        id: "ssh",
        auto_correct: true

      node.vm.provider "virtualbox" do |vb|
        vb.name = "tp-final-#{name}"
        vb.memory = opts[:memory]
        vb.cpus = opts[:cpus]
      end

      node.vm.provision "shell", inline: <<-SHELL
        set -eu
        export DEBIAN_FRONTEND=noninteractive
        apt-get update
        apt-get install -y ca-certificates curl gnupg python3 python3-apt sudo
        if [ "#{name}" = "k3s" ]; then
          apt-get install -y ansible openssh-client
          install -d -m 0700 -o vagrant -g vagrant /home/vagrant/.ssh
          cp /vagrant/.vagrant/machines/monitoring/virtualbox/private_key /home/vagrant/.ssh/insecure_private_key || true
          chown vagrant:vagrant /home/vagrant/.ssh/insecure_private_key || true
          chmod 0600 /home/vagrant/.ssh/insecure_private_key || true
        fi
        echo "vagrant ALL=(ALL) NOPASSWD:ALL" >/etc/sudoers.d/vagrant
        chmod 0440 /etc/sudoers.d/vagrant
      SHELL
    end
  end
end
